---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection, render } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const renderedPosts = await Promise.all(
	posts.map(async (post) => {
		const { Content } = await render(post);
		return { post, Content };
	}),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style is:global>
			html,
			body {
				height: 100%;
			}
			body {
				display: flex;
				flex-direction: column;
				overflow: hidden;
			}
		</style>
		<style>
			main {
				flex: 1;
				min-height: 0;
				display: flex;
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
				overflow: hidden;
			}

			/* ── Sidebar ── */
			.sidebar {
				width: 260px;
				flex-shrink: 0;
				border-right: 1px solid var(--border);
				background: var(--surface);
				display: flex;
				flex-direction: column;
				overflow-y: auto;
			}
			.sidebar-header {
				padding: 1rem;
				border-bottom: 1px solid var(--border);
				flex-shrink: 0;
			}
			.sidebar-title {
				display: block;
				font-size: 11px;
				font-weight: 500;
				color: var(--muted-foreground);
				text-transform: uppercase;
				letter-spacing: 0.08em;
				margin-bottom: 0.15rem;
			}
			.sidebar-count {
				display: block;
				font-size: 20px;
				font-weight: 900;
				color: var(--foreground);
				letter-spacing: -0.02em;
				line-height: 1;
			}
			.nav-list {
				list-style: none;
				margin: 0;
				padding: 0.5rem 0;
			}
			.nav-link {
				display: block;
				padding: 0.6rem 1rem;
				border-left: 2px solid transparent;
				text-decoration: none;
				color: var(--muted-foreground);
				transition:
					color 0.1s,
					background 0.1s,
					border-color 0.1s;
			}
			.nav-link:hover {
				color: var(--foreground);
				background: var(--muted);
			}
			.nav-link.active {
				border-left-color: var(--primary);
				color: var(--foreground);
				background: var(--muted);
			}
			.nav-link-title {
				display: block;
				font-size: 12px;
				font-weight: 700;
				line-height: 1.3;
				margin-bottom: 0.2rem;
			}
			.nav-link.active .nav-link-title {
				color: var(--primary);
			}
			.nav-link-date {
				display: block;
				font-size: 11px;
				color: var(--muted-foreground);
			}

			/* ── Scroll area ── */
			.scroll-area {
				flex: 1;
				min-width: 0;
				overflow-y: auto;
				scroll-behavior: smooth;
			}

			/* ── Individual post section ── */
			.post-section {
				padding: 2.5rem 2.5rem 3rem;
				max-width: 740px;
				border-bottom: 1px solid var(--border);
			}
			.post-meta {
				margin-bottom: 1.75rem;
			}
			.post-pub-date {
				display: block;
				font-size: 11px;
				font-weight: 500;
				color: var(--muted-foreground);
				text-transform: uppercase;
				letter-spacing: 0.06em;
				margin-bottom: 0.5rem;
			}
			.post-section h1 {
				margin: 0;
				font-size: 24px;
				font-weight: 700;
				letter-spacing: -0.01em;
				line-height: 1.2;
			}

			/* ── Prose ── */
			.prose p {
				font-size: 14px;
				line-height: 1.7;
				color: var(--foreground);
				margin-bottom: 1rem;
			}
			.prose h2 {
				font-size: 18px;
				font-weight: 700;
				margin: 2rem 0 0.5rem;
				letter-spacing: -0.01em;
			}
			.prose h3 {
				font-size: 14px;
				font-weight: 700;
				margin: 1.5rem 0 0.5rem;
			}
			.prose ul,
			.prose ol {
				padding-left: 1.5rem;
				margin-bottom: 1rem;
			}
			.prose li {
				font-size: 14px;
				line-height: 1.6;
				margin-bottom: 0.25rem;
			}
			.prose a {
				color: var(--primary);
			}
			.prose a:hover {
				color: var(--primary-dark);
			}
			.prose strong {
				font-weight: 700;
			}
			.prose code {
				background: var(--muted);
				padding: 2px 5px;
				font-size: 12px;
				font-feature-settings:
					"liga" 1,
					"calt" 1;
			}
			.prose pre {
				background: var(--muted);
				padding: 1rem;
				overflow-x: auto;
				margin-bottom: 1rem;
			}
			.prose pre code {
				background: none;
				padding: 0;
			}
			.prose blockquote {
				border-left: 4px solid var(--primary);
				padding: 0 0 0 1rem;
				margin: 0 0 1rem;
				color: var(--muted-foreground);
			}
			.prose hr {
				border: none;
				border-top: 1px solid var(--border);
				margin: 2rem 0;
			}
			.prose img {
				max-width: 100%;
			}
			.prose table {
				width: 100%;
				border-collapse: collapse;
				font-size: 13px;
				margin-bottom: 1rem;
			}
			.prose th,
			.prose td {
				border: 1px solid var(--border);
				padding: 0.5rem 0.75rem;
				text-align: left;
			}
			.prose th {
				background: var(--surface);
				font-weight: 700;
			}

			/* ── Mobile ── */
			@media (max-width: 720px) {
				body {
					overflow: auto;
				}
				main {
					flex-direction: column;
					overflow: visible;
				}
				.sidebar {
					width: 100%;
					border-right: none;
					border-bottom: 1px solid var(--border);
				}
				.scroll-area {
					overflow-y: visible;
				}
				.post-section {
					padding: 1.5rem 1rem 2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<nav class="sidebar" aria-label="Posts">
				<div class="sidebar-header">
					<span class="sidebar-title">Musings</span>
					<span class="sidebar-count">{posts.length}</span>
				</div>
				<ul class="nav-list">
					{
						posts.map((post) => (
							<li>
								<a
									href={`#${post.id}`}
									class="nav-link"
									data-target={post.id}
								>
									<span class="nav-link-title">
										{post.data.title}
									</span>
									<span class="nav-link-date">
										<FormattedDate
											date={post.data.pubDate}
										/>
									</span>
								</a>
							</li>
						))
					}
				</ul>
			</nav>
			<div class="scroll-area" id="scroll-area">
				{
					renderedPosts.map(({ post, Content }) => (
						<section id={post.id} class="post-section">
							<div class="post-meta">
								<span class="post-pub-date">
									<FormattedDate date={post.data.pubDate} />
								</span>
								<h1>{post.data.title}</h1>
							</div>
							<div class="prose">
								<Content />
							</div>
						</section>
					))
				}
			</div>
		</main>
		<Footer />
		<script>
			const scrollArea = document.getElementById("scroll-area")!;
			const sections =
				document.querySelectorAll<HTMLElement>(".post-section");
			const navLinks =
				document.querySelectorAll<HTMLAnchorElement>(".nav-link");

			navLinks.forEach((link) => {
				link.addEventListener("click", (e) => {
					e.preventDefault();
					const id = link.dataset.target!;
					const target = document.getElementById(id);
					if (target) {
						scrollArea.scrollTo({
							top: target.offsetTop,
							behavior: "smooth",
						});
					}
				});
			});

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							const id = entry.target.id;
							navLinks.forEach((link) => {
								link.classList.toggle(
									"active",
									link.dataset.target === id,
								);
							});
						}
					});
				},
				{ root: scrollArea, threshold: 0.25 },
			);

			sections.forEach((s) => observer.observe(s));
		</script>
	</body>
</html>
